# Oracle Cloud credentials
TENANCY_OCID=ocid1.tenancy.oc1..xxxx
USER_OCID=ocid1.user.oc1..xxxx
FINGERPRINT=12:34:56:78:90:ab:cd:ef
PRIVATE_KEY_PATH=/data/oci/oci_api_key.pem

# Region and compartment
REGION=us-phoenix-1
COMPARTMENT_OCID=ocid1.tenancy.oc1..xxxx

# Instance config
AVAILABILITY_DOMAIN=VyDi:PHX-AD-1,VyDi:PHX-AD-2,VyDi:PHX-AD-3
SHAPE=VM.Standard.A1.Flex
OCPUS=4
MEMORY_IN_GBS=24
DISK_SIZE=100
SUBNET_OCID=ocid1.subnet.oc1.phx.xxxx
IMAGE_OCID=ocid1.image.oc1.phx.xxxx
SSH_PUBLIC_KEY=ssh-ed25519 AAAA...

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polling interval (seconds)
CHECK_INTERVAL=600
